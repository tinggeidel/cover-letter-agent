# Copy this file to .env and fill in your real key.
# Get one at https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model used for all three passes.
# Defaults to claude-sonnet-4-6 (balance of quality and cost).
# Alternatives: claude-opus-4-7 (premium), claude-haiku-4-5-20251001 (cheap/fast).
# MODEL=claude-sonnet-4-6
